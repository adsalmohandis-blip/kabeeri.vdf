{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kabeeri.local/schemas/app_workspace_validation.schema.json",
  "title": "App Workspace Validation",
  "type": "object",
  "required": [
    "ok",
    "workspace_root",
    "selected_category",
    "present",
    "missing",
    "checks",
    "summary"
  ],
  "properties": {
    "ok": { "type": "boolean" },
    "workspace_root": { "type": "string" },
    "selected_category": { "type": "string" },
    "platform_type": { "type": "string" },
    "profile_version": { "type": "string" },
    "source_plugin": { "type": "string" },
    "present": {
      "type": "array",
      "items": { "type": "string" }
    },
    "missing": {
      "type": "array",
      "items": { "type": "string" }
    },
    "checks": {
      "type": "array",
      "items": { "type": "object" }
    },
    "summary": { "type": "object" }
  },
  "additionalProperties": true
}
