{
  "name": "kvdos",
  "private": true,
  "version": "1.0.0",
  "description": "KVDOS workspace starter for the commercial AI Software Factory OS.",
  "type": "commonjs",
  "scripts": {
    "start": "node src/index.js",
    "validate": "node src/validate.js",
    "status": "node src/status.js",
    "impl:baseline": "node src/implementation_baseline.js",
    "studio:shell": "node src/studio_shell.js",
    "qa:ide-journey": "node src/qa_ide_journey.js",
    "desktop:dev": "npm --prefix apps/desktop run dev",
    "desktop:build": "npm --prefix apps/desktop run build",
    "desktop:tauri:dev": "npm --prefix apps/desktop run tauri:dev",
    "desktop:tauri:build": "npm --prefix apps/desktop run tauri:build",
    "desktop:snapshot": "node scripts/generate_desktop_snapshot.js",
    "studio:tasks": "node src/studio_tasks_view.js",
    "task": "node src/tasks.js",
    "task:create": "node src/tasks.js create",
    "task:list": "node src/tasks.js list",
    "task:show": "node src/tasks.js show",
    "task:update": "node src/tasks.js update",
    "task:import": "node src/tasks.js import",
    "task:export": "node src/tasks.js export",
    "studio:dependencies": "node src/studio_dependencies.js",
    "queue:status": "node src/queue_status.js",
    "check": "node tests/implementation_baseline.test.js",
    "test": "node tests/app.test.js && node tests/runtime.test.js && node tests/tasks.test.js && node tests/studio_tasks.test.js && node tests/studio_presets.test.js && node tests/desktop_snapshot.test.js && node tests/desktop_ux.test.js && node tests/qa.test.js && node tests/implementation_baseline.test.js && node tests/studio_shell.test.js"
  }
}
