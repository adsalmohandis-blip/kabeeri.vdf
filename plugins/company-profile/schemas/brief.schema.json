{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Company Profile Builder Brief Schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["mode", "audience", "booking_rules", "ui", "system", "data"],
  "properties": {
    "mode": { "enum": ["startup", "corporate", "agency", "franchise"] },
    "audience": { "type": "string" },
    "booking_rules": { "type": "array", "items": { "type": "string" } },
    "ui": { "type": "array", "items": { "type": "string" } },
    "system": { "type": "array", "items": { "type": "string" } },
    "data": { "type": "array", "items": { "type": "string" } }
  },
  "oneOf": [
    { "properties": { "mode": { "const": "startup" } } },
    { "properties": { "mode": { "const": "corporate" } } },
    { "properties": { "mode": { "const": "agency" } } },
    { "properties": { "mode": { "const": "franchise" } } }
  ]
}
