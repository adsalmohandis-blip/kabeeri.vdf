{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "App Category Profile",
  "type": "object",
  "required": [
    "app_id",
    "app_name",
    "delivery_category",
    "domain_category",
    "architecture_pattern",
    "governance_profile",
    "selected_category_ids",
    "status",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "app_id": { "type": "string" },
    "app_name": { "type": "string" },
    "delivery_category": { "type": "string" },
    "domain_category": { "type": "string" },
    "architecture_pattern": { "type": "string" },
    "governance_profile": { "type": "string" },
    "industry_category": { "type": ["string", "null"] },
    "selected_category_ids": { "type": "array", "items": { "type": "string" } },
    "selected_category_versions": { "type": "array", "items": { "type": "string" } },
    "selected_groups": { "type": "array", "items": { "type": "string" } },
    "selected_specs_placeholder": { "type": "array", "items": { "type": "string" } },
    "status": { "type": "string" },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" }
  }
}
