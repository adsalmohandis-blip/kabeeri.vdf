{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Category",
  "type": "object",
  "required": [
    "id",
    "name",
    "description",
    "group",
    "layer",
    "lifecycle_status",
    "activation_status",
    "spec_status",
    "visibility",
    "version",
    "schema_version",
    "compatible_with",
    "required_uiux_specs",
    "required_system_design_specs",
    "required_database_specs",
    "required_questionnaire_packs",
    "required_roadmap_tracks",
    "workspace_template",
    "governance_profiles",
    "testing_focus",
    "readiness_checks"
  ],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "group": { "type": "string" },
    "layer": { "type": "string" },
    "lifecycle_status": { "enum": ["draft", "experimental", "beta", "stable", "deprecated"] },
    "activation_status": { "enum": ["active", "inactive", "admin_only", "hidden"] },
    "spec_status": { "enum": ["none", "partial", "ready", "verified"] },
    "visibility": { "enum": ["default", "advanced", "coming_soon", "hidden"] },
    "version": { "type": "string" },
    "schema_version": { "type": "string" },
    "compatible_with": { "type": "array", "items": { "type": "string" } },
    "required_uiux_specs": { "type": "array", "items": { "type": "string" } },
    "required_system_design_specs": { "type": "array", "items": { "type": "string" } },
    "required_database_specs": { "type": "array", "items": { "type": "string" } },
    "required_questionnaire_packs": { "type": "array", "items": { "type": "string" } },
    "required_roadmap_tracks": { "type": "array", "items": { "type": "string" } },
    "workspace_template": { "type": "string" },
    "governance_profiles": { "type": "array", "items": { "type": "string" } },
    "testing_focus": { "type": "array", "items": { "type": "string" } },
    "readiness_checks": { "type": "array", "items": { "type": "string" } }
  }
}
