    "kvdf plugins install ai_tool_adapters",
    "kvdf plugins uninstall ai_tool_adapters"
  ],
  "docs_surface": [
    "plugins/ai_tool_adapters/README.md",
    "plugins/ai_tool_adapters/governance/AI_TOOL_ADAPTER_ARCHITECTURE.md",
    "plugins/ai_tool_adapters/governance/AI_TOOL_ADAPTER_BOUNDARIES.md",
