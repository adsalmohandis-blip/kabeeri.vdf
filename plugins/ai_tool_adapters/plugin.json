{
  "plugin_id": "ai_tool_adapters",
  "name": "AI Tool Adapter",
  "plugin_version": "0.1.0",
  "bundle_type": "removable",
  "load_strategy": "manifest_driven",
  "runtime_entrypoint": "plugins/ai_tool_adapters/runtime/index.js",
  "command_entrypoint": "plugins/ai_tool_adapters/runtime/index.js",
  "removable": true,
  "track": "shared",
  "plugin_family": "integration_plugin",
  "plugin_type": "ai_tool_adapters",
  "enabled_by_default": true,
  "description": "Optional discovery and registration plugin for local AI tools. The bundle stays in the legacy ai_tool_adapters folder for compatibility, but the public-facing identity is ai_tool_adapter.",
  "required_folders": [
    "commands",
    "governance",
    "runtime",
    "schemas",
    "tests"
  ],
  "provides": [
    "ai_tool_registry",
    "ai_tool_scan",
    "ai_tool_catalog",
    "ai_tool_adaptation_pack_catalog",
    "ai_tool_prompt_profile_catalog",
    "ai_tool_prompt_composition",
    "ai_tool_capability_contract",
    "ai_tool_run_contract_later",
    "ai_tool_runner",
    "ai_tool_provider_api"
  ],
  "consumed_by": [
    {
      "plugin_id": "multi_ai_governance",
      "purpose": "Governed assignment execution through registered AI tools"
    }
  ],
  "command_surface": [
    "kvdf ai-tool-adapter status",
    "kvdf ai-tool-adapter scan",
    "kvdf ai-tool-adapter catalog",
    "kvdf ai-tool-adapter packs",
    "kvdf ai-tool-adapter prompts",
    "kvdf ai-tool-adapter prompt",
    "kvdf ai-tool-adapter compose",
    "kvdf ai-tool-adapter preset",
    "kvdf ai-tool-adapter blueprint",
    "kvdf ai-tool-adapter prompt-blueprint",
    "kvdf ai-tool-adapter list",
    "kvdf ai-tool-adapter register",
    "kvdf ai-tool-adapter unregister",
    "kvdf ai-tool-adapter show",
    "kvdf ai-tool-adapter provider",
    "kvdf ai-tool-adapter capabilities",
    "kvdf ai-tool-adapter can-run",
    "kvdf ai-tool-adapter evidence",
    "kvdf ai-tool-adapter dashboard",
    "kvdf ai-tool-adapter readiness",
    "kvdf ai-tool-adapter audit",
    "kvdf ai-tool-adapters status",
    "kvdf ai-tool-adapters scan",
    "kvdf ai-tool-adapters catalog",
    "kvdf ai-tool-adapters packs",
    "kvdf ai-tool-adapters prompts",
    "kvdf ai-tool-adapters prompt",
    "kvdf ai-tool-adapters compose",
    "kvdf ai-tool-adapters preset",
    "kvdf ai-tool-adapters blueprint",
    "kvdf ai-tool-adapters prompt-blueprint",
    "kvdf ai-tool-adapters list",
