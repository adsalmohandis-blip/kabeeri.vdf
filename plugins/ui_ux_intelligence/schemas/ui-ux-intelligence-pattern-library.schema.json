{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UI UX Intelligence Pattern Library",
  "type": "object",
  "additionalProperties": true,
  "required": ["report_type", "input", "patterns", "recommended_order", "standalone", "external_github_dependency"],
  "properties": {
    "report_type": { "const": "ui_ux_intelligence_pattern_library" },
    "input": { "type": "string" },
    "patterns": { "type": "array" },
    "recommended_order": { "type": "array" },
    "standalone": { "type": "boolean" },
    "external_github_dependency": { "type": "boolean" },
    "next_action": { "type": "string" }
  }
}
