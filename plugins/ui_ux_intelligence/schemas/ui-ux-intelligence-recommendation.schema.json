{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UI UX Intelligence Recommendation",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "report_type",
    "input",
    "detected_product_type",
    "recommended_style",
    "recommended_palette_mood",
    "recommended_typography_mood",
    "recommended_layout_patterns",
    "recommended_components",
    "ux_rules",
    "anti_patterns_to_avoid",
    "chart_recommendations",
    "icon_recommendations",
    "stack_guidance",
    "accessibility_notes",
    "responsive_notes",
    "warnings",
    "confidence",
    "standalone",
    "external_github_dependency",
    "next_action"
  ],
  "properties": {
    "report_type": { "const": "ui_ux_intelligence_recommendation" },
    "input": { "type": "string" },
    "detected_product_type": {
      "anyOf": [
        { "type": "string" },
        { "type": "object" }
      ]
    },
    "detected_product_type_details": { "type": "object" },
    "recommended_style": {
      "anyOf": [
        { "type": "string" },
        { "type": "object" }
      ]
    },
    "recommended_style_details": { "type": "object" },
    "recommended_palette_mood": {
      "anyOf": [
        { "type": "string" },
        { "type": "object" }
      ]
    },
    "recommended_palette_details": { "type": "object" },
    "recommended_typography_mood": {
      "anyOf": [
        { "type": "string" },
        { "type": "object" }
      ]
    },
    "recommended_typography_details": { "type": "object" },
    "recommended_layout_patterns": {
      "type": "array",
      "items": { "type": "string" }
    },
    "recommended_layout_pattern_details": {
      "type": "array",
      "items": { "type": "object" }
    },
    "recommended_components": {
      "type": "array",
      "items": { "type": "string" }
    },
    "ux_rules": {
      "type": "array",
      "items": { "type": "string" }
    },
    "anti_patterns_to_avoid": {
      "type": "array",
      "items": { "type": "string" }
    },
    "chart_recommendations": {
      "type": "array",
      "items": { "type": "object" }
    },
    "icon_recommendations": {
      "type": "array",
      "items": { "type": "object" }
    },
    "stack_guidance": {
      "type": "array",
      "items": { "type": "object" }
    },
    "accessibility_notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "responsive_notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "confidence": { "enum": ["low", "medium", "high"] },
    "standalone": { "const": true },
    "external_github_dependency": { "const": false },
    "next_action": { "type": "string" }
  }
}
