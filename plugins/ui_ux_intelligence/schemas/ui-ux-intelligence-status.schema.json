{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UI UX Intelligence Status",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "report_type",
    "plugin_id",
    "status",
    "standalone",
    "external_github_dependency",
    "catalog_ready",
    "capabilities",
    "next_action"
  ],
  "properties": {
    "report_type": { "const": "ui_ux_intelligence_status" },
    "plugin_id": { "const": "ui_ux_intelligence" },
    "status": { "enum": ["available", "missing", "disabled"] },
    "standalone": { "type": "boolean" },
    "external_github_dependency": { "type": "boolean" },
    "catalog_ready": { "type": "boolean" },
    "capabilities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "next_action": { "type": "string" }
  }
}
