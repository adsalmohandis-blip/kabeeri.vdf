{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UI UX Intelligence Design System",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "report_type",
    "input",
    "product_type",
    "style",
    "colors",
    "typography",
    "layout_patterns",
    "components",
    "motion_rules",
    "accessibility",
    "anti_patterns",
    "pre_delivery_checklist",
    "warnings",
    "standalone",
    "external_github_dependency",
    "next_action"
  ],
  "properties": {
    "report_type": { "const": "ui_ux_intelligence_design_system" },
    "input": { "type": "string" },
    "product_type": { "type": "object" },
    "style": { "type": "object" },
    "colors": { "type": "object" },
    "typography": { "type": "object" },
    "components": {
      "type": "array",
      "items": { "type": "string" }
    },
    "layout_patterns": {
      "type": "array",
      "items": { "type": "string" }
    },
    "layout_system": { "type": "object" },
    "component_guidance": { "type": "object" },
    "motion_rules": {
      "type": "array",
      "items": { "type": "string" }
    },
    "accessibility": { "type": "object" },
    "anti_patterns": {
      "type": "array",
      "items": { "type": "string" }
    },
    "pre_delivery_checklist": {
      "type": "array",
      "items": { "type": "string" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "standalone": { "const": true },
    "external_github_dependency": { "const": false },
    "next_action": { "type": "string" }
  }
}
