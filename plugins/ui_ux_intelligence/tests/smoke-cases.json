{
  "plugin_id": "ui_ux_intelligence",
  "smoke_cases": [
    {
      "command": "kvdf ui-ux-intelligence status --json",
      "expect_report_type": "ui_ux_intelligence_status"
    },
    {
      "command": "kvdf ui-ux-intelligence source-status --json",
      "expect_report_type": "ui_ux_intelligence_source_status"
    },
    {
      "command": "kvdf ui-ux-intelligence recommend --idea \"Build booking app for clinics\" --json",
      "expect_report_type": "ui_ux_intelligence_recommendation"
    },
    {
      "command": "kvdf ui-ux-intelligence design-system --idea \"Build ecommerce app\" --json",
      "expect_report_type": "ui_ux_intelligence_design_system"
    },
    {
      "command": "kvdf ui-ux-intelligence checklist --idea \"Build dashboard app\" --json",
      "expect_report_type": "ui_ux_intelligence_checklist"
    },
    {
      "command": "kvdf ui-ux-intelligence docs --idea \"Build booking app\" --track vibe --app booking --json",
      "expect_report_type": "ui_ux_intelligence_docs_sections"
    },
    {
      "command": "kvdf ui-ux-intelligence audit --target docs/ui-ux/UI_UX_DESIGN.md --json",
      "expect_report_type": "ui_ux_intelligence_audit"
    }
  ]
}
