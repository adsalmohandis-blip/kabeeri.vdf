    "kvdf ui-ux-intelligence knowledge-pack",
    "kvdf ui-ux-intelligence catalog-health",
    "kvdf ui-ux-intelligence governance-registry",
    "kvdf ui-ux-intelligence upgrade-plan",
    "kvdf ui-ux-intelligence governance",
    "kvdf plugins install ui_ux_intelligence",
    "kvdf plugins uninstall ui_ux_intelligence"
  ],
  "docs_surface": [
    "plugins/ui_ux_intelligence/README.md",
    "plugins/ui_ux_intelligence/docs/index.md",
    "plugins/ui_ux_intelligence/docs/cli.md"
  ]
