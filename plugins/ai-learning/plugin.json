{
  "plugin_id": "ai-learning",
  "name": "AI Learning",
  "plugin_version": "0.1.0",
  "bundle_type": "removable",
  "load_strategy": "manifest_driven",
  "command_entrypoint": "plugins/ai-learning/bootstrap.js",
  "runtime_entrypoint": "plugins/ai-learning/runtime/index.js",
  "removable": true,
  "track": "shared",
  "plugin_family": "knowledge",
  "plugin_type": "ai-learning",
  "enabled_by_default": false,
  "description": "Optional AI learning plugin that packages local failure capture, sanitized export/import, owner review, promotion, shared learning, local cache sync, and future cloud-ready metadata on top of the core memory layer.",
  "required_folders": [
    "runtime",
    "docs"
  ],
  "optional_folders": [
    "tests",
    "assets",
    "references"
  ],
  "domain_folders": [
    "runtime",
    "docs",
    "tests"
  ],
  "command_surface": [
    "kvdf learn capture",
    "kvdf learn fast-path",
    "kvdf learn export",
    "kvdf learn import",
    "kvdf learn review",
    "kvdf learn promote",
    "kvdf learn reject",
    "kvdf learn shared",
    "kvdf learn cache update",
    "kvdf learn cache list",
    "kvdf learn metadata",
    "kvdf learn prompt-context",
    "kvdf plugins install ai-learning",
    "kvdf plugins uninstall ai-learning"
  ],
  "docs_surface": [
    "plugins/ai-learning/README.md",
    "plugins/ai-learning/docs/index.md",
    "plugins/ai-learning/docs/cli.md"
  ]
}
