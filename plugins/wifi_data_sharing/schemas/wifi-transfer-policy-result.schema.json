{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "wifi-transfer-policy-result.schema.json",
  "title": "Wi-Fi Transfer Policy Result",
  "type": "object",
  "required": ["policy_result_id", "package_id", "status", "checks", "blockers", "warnings", "generated_at", "next_action"],
  "properties": {
    "policy_result_id": { "type": "string" },
    "package_id": { "type": ["string", "null"] },
    "sender_node_id": { "type": ["string", "null"] },
    "status": { "type": "string", "enum": ["pass", "warn", "fail", "blocked"] },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["check_id", "status", "message"],
        "properties": {
          "check_id": { "type": "string" },
          "status": { "type": "string", "enum": ["pass", "warn", "fail", "blocked"] },
          "message": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "blockers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "generated_at": { "type": "string" },
    "next_action": { "type": "string" }
  },
  "additionalProperties": true
}
