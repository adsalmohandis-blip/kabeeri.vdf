{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "wifi-data-inbox.schema.json",
  "title": "Wi-Fi Data Inbox Index",
  "type": "object",
  "required": ["version", "plugin_id", "inbox"],
  "properties": {
    "version": { "type": "string" },
    "plugin_id": { "const": "wifi_data_sharing" },
    "created_at": { "type": ["string", "null"] },
    "updated_at": { "type": ["string", "null"] },
    "inbox": {
      "type": "array",
      "items": { "$ref": "./wifi-data-package.schema.json" }
    }
  },
  "additionalProperties": true
}
