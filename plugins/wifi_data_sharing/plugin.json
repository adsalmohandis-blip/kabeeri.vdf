{
  "plugin_id": "wifi_data_sharing",
  "name": "Wi-Fi Data Sharing",
  "plugin_version": "0.1.0",
  "bundle_type": "removable",
  "load_strategy": "manifest_driven",
  "runtime_entrypoint": "plugins/wifi_data_sharing/bootstrap.js",
  "command_entrypoint": "plugins/wifi_data_sharing/bootstrap.js",
  "removable": true,
  "track": "shared",
  "plugin_family": "integration_plugin",
  "plugin_type": "wifi_data_sharing",
  "enabled_by_default": true,
  "description": "Local Wi-Fi/LAN data sharing provider for trusted KVDF/KVDOS nodes.",
  "required_folders": [
    "commands",
    "governance",
    "runtime",
    "schemas",
    "tests",
    "transport",
    "simulation"
  ],
  "provides": [
    "lan_node_identity",
    "lan_node_discovery_later",
    "trusted_node_registry_later",
    "data_package_transfer_later",
    "wifi_data_provider_api_later",
    "wifi_data_provider_api",
    "lan_node_discovery",
    "trusted_node_registry",
    "data_package_transfer",
    "transfer_inbox",
    "wifi_data_packages",
    "wifi_data_inbox",
    "wifi_data_outbox",
