{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ecommerce Mobile App Builder Brief Schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["mode", "audience", "booking_rules", "ui", "system", "data"],
  "properties": {
    "mode": { "enum": ["shopping", "marketplace", "subscription", "loyalty"] },
    "audience": { "type": "string" },
    "booking_rules": { "type": "array", "items": { "type": "string" } },
    "ui": { "type": "array", "items": { "type": "string" } },
    "system": { "type": "array", "items": { "type": "string" } },
    "data": { "type": "array", "items": { "type": "string" } }
  },
  "oneOf": [
    { "properties": { "mode": { "const": "shopping" } } },
    { "properties": { "mode": { "const": "marketplace" } } },
    { "properties": { "mode": { "const": "subscription" } } },
    { "properties": { "mode": { "const": "loyalty" } } }
  ]
}
