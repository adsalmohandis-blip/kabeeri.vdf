{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Blog Builder Brief Schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["mode", "audience", "booking_rules", "ui", "system", "data"],
  "properties": {
    "mode": { "enum": ["personal", "multi-author", "business", "technical"] },
    "audience": { "type": "string" },
    "booking_rules": { "type": "array", "items": { "type": "string" } },
    "ui": { "type": "array", "items": { "type": "string" } },
    "system": { "type": "array", "items": { "type": "string" } },
    "data": { "type": "array", "items": { "type": "string" } }
  },
  "oneOf": [
    { "properties": { "mode": { "const": "personal" } } },
    { "properties": { "mode": { "const": "multi-author" } } },
    { "properties": { "mode": { "const": "business" } } },
    { "properties": { "mode": { "const": "technical" } } }
  ]
}
