{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GitHub Provider Issue Plan",
  "type": "object",
  "required": ["report_type", "planned_issues", "dry_run", "next_action"],
  "properties": {
    "report_type": { "const": "github_provider_issue_plan" },
    "planned_issues": { "type": "array" },
    "dry_run": { "type": "boolean" },
    "next_action": { "type": "string" }
  },
  "additionalProperties": true
}
