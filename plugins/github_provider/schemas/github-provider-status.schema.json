{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GitHub Provider Status",
  "type": "object",
  "required": ["report_type", "plugin_id", "status", "provider", "remote_provider", "enabled_by_default", "writes_remote_by_default", "canonical_provider", "next_action"],
  "properties": {
    "report_type": { "const": "github_provider_status" },
    "plugin_id": { "const": "github_provider" },
    "status": { "type": "string" },
    "provider": { "type": "string" },
    "remote_provider": { "type": "string" },
    "enabled_by_default": { "type": "boolean" },
    "writes_remote_by_default": { "type": "boolean" },
    "canonical_provider": { "type": "boolean" },
    "next_action": { "type": "string" }
  },
  "additionalProperties": true
}
