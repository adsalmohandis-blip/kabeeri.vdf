  "domain_folders": ["business-type", "references", "examples", "assets", "dashboard"],
  "command_surface": [
    "kvdf crm status",
    "kvdf crm init",
    "kvdf crm questionnaire",
    "kvdf crm brief",
    "kvdf crm design",
    "kvdf crm modules",
    "kvdf crm tasks",
    "kvdf crm approve",
    "kvdf crm report",
    "kvdf plugins install crm",
    "kvdf plugins uninstall crm"
  ],
  "docs_surface": [
    "plugins/crm/README.md",
    "plugins/crm/docs/index.md",
    "plugins/crm/docs/cli.md"
