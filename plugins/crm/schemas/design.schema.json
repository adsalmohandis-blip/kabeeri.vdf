{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CRM Builder Design Schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["mode", "ui_patterns", "system_patterns", "page_map", "module_hints", "design_summary"],
  "properties": {
    "mode": { "enum": ["sales", "support", "operations", "b2b"] },
    "ui_patterns": { "type": "array", "items": { "type": "string" } },
    "system_patterns": { "type": "array", "items": { "type": "string" } },
    "page_map": { "type": "array" },
    "module_hints": { "type": "array" },
    "design_summary": { "type": "object" }
  },
  "oneOf": [
    { "properties": { "mode": { "const": "sales" } } },
    { "properties": { "mode": { "const": "support" } } },
    { "properties": { "mode": { "const": "operations" } } },
    { "properties": { "mode": { "const": "b2b" } } }
  ]
}
