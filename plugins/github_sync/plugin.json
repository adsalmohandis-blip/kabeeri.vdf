{
  "plugin_id": "github_sync",
  "name": "GitHub Sync Rules Bundle",
  "plugin_version": "1.0.0",
  "bundle_type": "removable",
  "load_strategy": "manifest_driven",
  "command_entrypoint": "plugins/github_sync/bootstrap.js",
  "runtime_entrypoint": null,
  "removable": true,
  "track": "shared",
  "plugin_family": "platform_plugin",
  "plugin_type": "integration_bundle",
  "enabled_by_default": false,
  "canonical_provider": false,
  "superseded_by": "github_provider",
  "description": "Deprecated compatibility bundle superseded by the canonical github_provider plugin.",
  "command_surface": [
    "kvdf plugins install github_sync",
    "kvdf plugins uninstall github_sync"
  ],
  "docs_surface": [
    "plugins/github_sync/README.md",
    "plugins/github_sync/GITHUB_SYNC_RULES.md",
    "plugins/github_sync/GITHUB_ISSUE_MAPPING.md"
  ]
}
