  "docs_surface": [
    "plugins/plugin_folder_structure/docs/README.md",
    "plugins/plugin_folder_structure/docs/OVERVIEW.md",
    "plugins/plugin_folder_structure/docs/TRACK_BOUNDARIES.md",
    "plugins/plugin_folder_structure/docs/COMMANDS.md",
    "plugins/plugin_folder_structure/docs/ACCEPTANCE_CRITERIA.md",
    "plugins/plugin_folder_structure/docs/OWNER_TRACK_DIRECT_PLUGIN_FLOW.md",
    "plugins/plugin_folder_structure/docs/PLUGIN_DEVELOPMENT_TRACK_FLOW.md",
    "plugins/plugin_folder_structure/docs/VIBER_TRACK_BLOCKING_RULE.md",
    "plugins/plugin_folder_structure/docs/GIT_LIBRARY_INPUTS.md",
    "plugins/plugin_folder_structure/docs/INTEGRATIONS.md",
    "plugins/plugin_folder_structure/docs/PLUGIN_INTEGRATION_LAYER.md",
    "plugins/plugin_folder_structure/docs/MARKETPLACE_REQUEST_FLOW.md",
    "plugins/plugin_folder_structure/docs/git_libraries/README.md"
  ]
