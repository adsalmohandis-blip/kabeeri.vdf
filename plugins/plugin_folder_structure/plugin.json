    "kvdf plugin-folder integration validate <plugin-slug>",
    "kvdf plugin-folder request-owner-review <plugin-slug>",
    "kvdf plugin-folder request-marketplace-upload <plugin-slug>",
    "kvdf plugin-folder init-source <plugin-slug>"
