{
  "plugin_id": "planner-visual",
  "name": "Planner Visual Renderer",
  "plugin_version": "0.1.0",
  "bundle_type": "removable",
  "load_strategy": "manifest_driven",
  "runtime_entrypoint": "plugins/planner_visual/runtime/index.js",
  "removable": true,
  "track": "shared",
  "plugin_family": "planner",
  "plugin_type": "visual_renderer",
  "enabled_by_default": false,
  "description": "Render planner visual JSON into readable Markdown and Mermaid text without moving planner logic out of KVDF Core.",
  "required_folders": [
    "docs",
    "runtime",
    "schemas",
    "tests"
  ],
  "optional_folders": [
    "assets",
    "examples"
  ],
  "domain_folders": [
    "rendering",
    "reports"
  ],
  "command_surface": [
    "kvdf planner-visual status",
    "kvdf planner-visual render",
    "kvdf planner-visual export",
    "kvdf plugins install planner-visual",
    "kvdf plugins uninstall planner-visual"
  ],
  "docs_surface": [
    "plugins/planner_visual/docs/index.md",
    "plugins/planner_visual/docs/cli.md"
  ]
}
