{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "News Website Builder Approval Schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["batch_id", "mode", "approved", "blockers", "tasks", "next_action"],
  "properties": {
    "batch_id": { "type": "string" },
    "mode": { "enum": ["editorial", "magazine", "local-news", "newsletter"] },
    "approved": { "type": "boolean" },
    "blockers": { "type": "array", "items": { "type": "string" } },
    "tasks": { "type": "array" },
    "next_action": { "type": "string" }
  },
  "oneOf": [
    { "properties": { "mode": { "const": "editorial" } } },
    { "properties": { "mode": { "const": "magazine" } } },
    { "properties": { "mode": { "const": "local-news" } } },
    { "properties": { "mode": { "const": "newsletter" } } }
  ]
}
