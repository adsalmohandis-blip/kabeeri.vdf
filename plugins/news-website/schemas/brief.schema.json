{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "News Website Builder Brief Schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["mode", "audience", "booking_rules", "ui", "system", "data"],
  "properties": {
    "mode": { "enum": ["editorial", "magazine", "local-news", "newsletter"] },
    "audience": { "type": "string" },
    "booking_rules": { "type": "array", "items": { "type": "string" } },
    "ui": { "type": "array", "items": { "type": "string" } },
    "system": { "type": "array", "items": { "type": "string" } },
    "data": { "type": "array", "items": { "type": "string" } }
  },
  "oneOf": [
    { "properties": { "mode": { "const": "editorial" } } },
    { "properties": { "mode": { "const": "magazine" } } },
    { "properties": { "mode": { "const": "local-news" } } },
    { "properties": { "mode": { "const": "newsletter" } } }
  ]
}
