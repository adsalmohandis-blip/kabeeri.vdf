{
  "plugin_id": "kvdf-dev",
  "name": "KVDF Dev System Bundle",
  "plugin_version": "1.0.0",
  "bundle_type": "removable",
  "load_strategy": "manifest_driven",
  "command_entrypoint": "plugins/kvdf-dev/bootstrap.js",
  "runtime_entrypoint": "plugins/kvdf-dev/runtime/index.js",
  "removable": true,
  "track": "framework_owner",
  "plugin_family": "framework_plugin",
  "plugin_type": "kvdf_core",
  "enabled_by_default": true,
  "description": "Removable framework-development bundle that keeps KVDF itself separate from app-building plugins and app-track workflows.",
  "required_folders": [
    "commands",
    "docs",
    "prompts",
    "schemas",
    "templates",
    "tests"
  ],
  "optional_folders": [
    "references",
    "examples",
    "assets",
    "dashboard"
  ],
  "domain_folders": [
    "governance",
    "evolution",
    "capabilities",
    "runtime",
    "plugin-control",
    "tracks",
    "reports"
  ],
  "command_surface": [
    "kvdf evolution",
    "kvdf evolution roadmap",
    "kvdf evolution priorities",
    "kvdf evolution partition",
    "kvdf evolution batch-exe",
    "kvdf batch-exe",
    "kvdf task packet",
    "kvdf task executor-contract",
    "kvdf task batch-run",
    "kvdf cleaner cleanup",
    "kvdf maintenance",
    "kvdf maintenance fast",
    "kvdf maintenance slow",
    "kvdf cleaner inspect",
    "kvdf cleaner relocate review",
    "kvdf cleaner relocate",
    "kvdf cleaner report",
    "kvdf cleaner approve --confirm",
    "kvdf cleaner execute",
    "kvdf cleaner finalize",
    "kvdf plugins install kvdf-dev",
    "kvdf plugins enable kvdf-dev",
    "kvdf plugins uninstall kvdf-dev",
    "kvdf plugins disable kvdf-dev"
  ],
  "docs_surface": [
    "plugins/kvdf-dev/docs/index.md",
    "knowledge/governance/EVOLUTION_STEWARD.md",
    "docs/reports/KVDF_CORE_PLUGIN_CAPABILITY_SPLIT_STUDY.md"
  ]
}
