{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Planner Visual Render Artifact",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "report_type",
    "plugin_id",
    "renderer",
    "rendered_markdown",
    "source_visual_report_type",
    "generated_at"
  ],
  "properties": {
    "report_type": {
      "type": "string",
      "const": "planner_visual_plugin_render"
    },
    "plugin_id": {
      "type": "string",
      "minLength": 1
    },
    "renderer": {
      "type": "string",
      "enum": ["mermaid_text"]
    },
    "rendered_markdown": {
      "type": "string",
      "minLength": 1
    },
    "source_visual_report_type": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
