{
  "title": "KVDF Planner Visual",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "report_type",
    "planner_mode",
    "track",
    "delivery_mode",
    "goal",
    "graph",
    "board",
    "scope_map",
    "legend",
    "planning_lifecycle",
    "gate_matrix",
    "blockers",
    "readiness_summary",
    "publish_readiness",
    "execution_feedback",
    "stage_timeline",
    "dashboard_summary",
    "validation_commands",
    "stop_condition",
    "markdown_report"
  ],
  "properties": {
    "report_type": {
      "type": "string",
      "const": "kvdf_planner_visual"
    },
    "planner_mode": {
      "type": "string",
      "enum": ["owner", "vibe", "plugin"]
    },
    "track": {
      "type": "string",
      "enum": ["framework_owner", "vibe_app_developer", "plugin"]
    },
    "delivery_mode": {
      "type": "string",
      "enum": ["direct_main", "local_first"]
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "source_control": {
      "type": ["object", "null"],
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "provider": { "type": "string" },
        "remote_provider": { "type": "string" },
        "provider_plugin": { "type": ["string", "null"] },
        "mode": { "type": "string" },
        "branching_enabled": { "type": "boolean" },
        "pr_enabled": { "type": "boolean" },
        "default_branch": { "type": "string" },
        "current_branch": { "type": ["string", "null"] },
        "requires_owner_approval": { "type": "boolean" },
        "replaceable_provider": { "type": "boolean" },
        "notes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "planning_lifecycle": {
      "type": "object",
      "required": ["method", "confidence", "reason", "current_version", "next_version", "current_evolution", "next_evolution", "state_freshness", "source_of_truth"],
      "properties": {
        "method": { "type": "string", "enum": ["state_resync", "planner_current", "goal_based", "manual"] },
        "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
        "reason": { "type": "string" },
        "current_version": { "type": ["string", "null"] },
        "next_version": { "type": ["string", "null"] },
        "current_evolution": { "type": ["string", "null"] },
        "next_evolution": { "type": ["string", "null"] },
        "state_freshness": { "type": "string", "enum": ["current", "stale", "unknown"] },
        "source_of_truth": { "type": "string", "enum": ["file_first", "runtime_only", "git_supported", "remote_supported", "unknown"] }
      }
    },
    "viber_pipeline": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "execution_allowed": {
      "type": ["boolean", "null"]
    },
    "execution_blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity", "area", "message", "next_action"],
        "properties": {
          "id": { "type": "string" },
          "severity": { "type": "string", "enum": ["blocker", "warning"] },
          "area": { "type": "string" },
          "message": { "type": "string" },
          "next_action": { "type": "string" }
        }
      }
    },
    "next_stage": {
      "type": ["string", "null"]
    },
    "gate_matrix": {
      "type": "object",
      "required": ["state_resync", "docs", "evolution", "task", "validation", "security", "handoff", "publish"],
      "properties": {
        "state_resync": {
          "type": "object",
          "required": ["gate", "status", "summary", "blockers", "warnings", "next_action"],
          "properties": {
            "gate": { "type": "string" },
            "status": { "type": "string", "enum": ["pass", "warning", "blocked", "unknown"] },
            "summary": { "type": "string" },
            "blockers": { "type": "array", "items": { "type": "string" } },
            "warnings": { "type": "array", "items": { "type": "string" } },
            "next_action": { "type": "string" }
          }
        },
        "docs": {
          "type": "object",
          "required": ["gate", "status", "summary", "blockers", "warnings", "next_action"],
          "properties": {
            "gate": { "type": "string" },
            "status": { "type": "string", "enum": ["pass", "warning", "blocked", "unknown"] },
            "summary": { "type": "string" },
            "blockers": { "type": "array", "items": { "type": "string" } },
            "warnings": { "type": "array", "items": { "type": "string" } },
            "next_action": { "type": "string" }
          }
        },
        "evolution": {
          "type": "object",
          "required": ["gate", "status", "summary", "blockers", "warnings", "next_action"],
          "properties": {
            "gate": { "type": "string" },
            "status": { "type": "string", "enum": ["pass", "warning", "blocked", "unknown"] },
            "summary": { "type": "string" },
            "blockers": { "type": "array", "items": { "type": "string" } },
            "warnings": { "type": "array", "items": { "type": "string" } },
            "next_action": { "type": "string" }
          }
        },
        "task": {
          "type": "object",
          "required": ["gate", "status", "summary", "blockers", "warnings", "next_action"],
          "properties": {
            "gate": { "type": "string" },
            "status": { "type": "string", "enum": ["pass", "warning", "blocked", "unknown"] },
            "summary": { "type": "string" },
            "blockers": { "type": "array", "items": { "type": "string" } },
            "warnings": { "type": "array", "items": { "type": "string" } },
            "next_action": { "type": "string" }
          }
        },
        "validation": {
          "type": "object",
          "required": ["gate", "status", "summary", "blockers", "warnings", "next_action"],
          "properties": {
            "gate": { "type": "string" },
            "status": { "type": "string", "enum": ["pass", "warning", "blocked", "unknown"] },
            "summary": { "type": "string" },
            "blockers": { "type": "array", "items": { "type": "string" } },
            "warnings": { "type": "array", "items": { "type": "string" } },
            "next_action": { "type": "string" }
          }
        },
        "security": {
          "type": "object",
          "required": ["gate", "status", "summary", "blockers", "warnings", "next_action"],
          "properties": {
            "gate": { "type": "string" },
            "status": { "type": "string", "enum": ["pass", "warning", "blocked", "unknown"] },
            "summary": { "type": "string" },
            "blockers": { "type": "array", "items": { "type": "string" } },
            "warnings": { "type": "array", "items": { "type": "string" } },
            "next_action": { "type": "string" }
          }
        },
        "handoff": {
          "type": "object",
          "required": ["gate", "status", "summary", "blockers", "warnings", "next_action"],
          "properties": {
            "gate": { "type": "string" },
            "status": { "type": "string", "enum": ["pass", "warning", "blocked", "unknown"] },
            "summary": { "type": "string" },
            "blockers": { "type": "array", "items": { "type": "string" } },
            "warnings": { "type": "array", "items": { "type": "string" } },
            "next_action": { "type": "string" }
          }
        },
        "publish": {
          "type": "object",
          "required": ["gate", "status", "summary", "blockers", "warnings", "next_action"],
          "properties": {
            "gate": { "type": "string" },
            "status": { "type": "string", "enum": ["pass", "warning", "blocked", "unknown"] },
            "summary": { "type": "string" },
            "blockers": { "type": "array", "items": { "type": "string" } },
            "warnings": { "type": "array", "items": { "type": "string" } },
            "next_action": { "type": "string" }
          }
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity", "area", "message", "next_action"],
        "properties": {
          "id": { "type": "string" },
          "severity": { "type": "string", "enum": ["blocker", "warning"] },
          "area": { "type": "string", "enum": ["state_resync", "docs", "task", "validation", "security", "handoff", "publish", "source_control"] },
          "message": { "type": "string" },
          "next_action": { "type": "string" }
        }
      }
    },
    "readiness_summary": {
      "type": "object",
      "required": ["docs_status", "task_status", "evolution_status", "validation_status", "security_status", "handoff_status"],
      "properties": {
        "docs_status": { "type": "string", "enum": ["planned", "missing", "generated", "applied_to_stage", "unknown"] },
        "task_status": { "type": "string", "enum": ["pending", "in_progress", "completed", "archived", "unknown"] },
        "evolution_status": { "type": "string", "enum": ["planned", "active", "blocked", "completed", "unknown"] },
        "validation_status": { "type": "string", "enum": ["pass", "warning", "blocked", "unknown"] },
        "security_status": { "type": "string", "enum": ["pass", "warning", "blocked", "unknown"] },
        "handoff_status": { "type": "string", "enum": ["not_started", "ready", "blocked", "unknown"] }
      }
    },
    "publish_readiness": {
      "type": "object",
      "required": ["status", "score", "label", "auto_publish", "rule", "next_action"],
      "properties": {
        "status": { "type": "string", "enum": ["ready", "warning", "blocked"] },
        "score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "label": { "type": "string" },
        "auto_publish": { "type": "boolean", "const": false },
        "rule": { "type": "string" },
        "next_action": { "type": "string" }
      }
    },
    "execution_feedback": {
      "type": "object",
      "required": ["status", "executor", "checks_run", "changed_files", "warnings", "stop_condition", "updated_at"],
      "properties": {
        "status": { "type": "string", "enum": ["none", "old", "current"] },
        "executor": { "type": ["string", "null"] },
        "checks_run": { "type": "array", "items": { "type": "string" } },
        "changed_files": { "type": "array", "items": { "type": "string" } },
        "warnings": { "type": "array", "items": { "type": "string" } },
        "stop_condition": { "type": "string" },
        "updated_at": { "type": ["string", "null"] }
      }
    },
    "stage_timeline": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "required": ["stage", "status", "outputs", "next_action"],
        "properties": {
          "stage": { "type": "string", "enum": ["idea", "requirements", "design", "implementation", "validation", "handoff"] },
          "status": { "type": "string", "enum": ["pass", "warning", "blocked", "unknown"] },
          "outputs": { "type": "array", "items": { "type": "string" } },
          "next_action": { "type": "string" }
        }
      }
    },
    "dashboard_summary": {
      "type": "object",
      "required": ["version_to_publish_summary", "gate_summary", "readiness_label", "blocked_total", "warnings_total"],
      "properties": {
        "version_to_publish_summary": { "type": "object", "additionalProperties": true },
        "gate_summary": { "type": "object", "additionalProperties": true },
        "readiness_label": { "type": "string" },
        "blocked_total": { "type": "integer", "minimum": 0 },
        "warnings_total": { "type": "integer", "minimum": 0 }
      }
    },
    "state_resync": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "graph": {
      "type": "object",
      "required": ["format", "diagram"],
      "properties": {
        "format": {
          "type": "string",
          "const": "mermaid"
        },
        "diagram": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "board": {
      "type": "object",
      "required": ["columns"],
      "properties": {
        "columns": {
          "type": "array",
          "minItems": 6,
          "items": {
            "type": "object",
            "required": ["id", "title", "cards"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "title": { "type": "string", "minLength": 1 },
              "cards": { "type": "array" }
            }
          }
        }
      }
    },
    "scope_map": {
      "type": "object",
      "required": ["allowed_files", "forbidden_files", "runtime_state", "generated_artifacts", "docs", "tests"],
      "properties": {
        "allowed_files": { "type": "array", "items": { "type": "string" } },
        "forbidden_files": { "type": "array", "items": { "type": "string" } },
        "runtime_state": { "type": "array", "items": { "type": "string" } },
        "generated_artifacts": { "type": "array", "items": { "type": "string" } },
        "docs": { "type": "array", "items": { "type": "string" } },
        "tests": { "type": "array", "items": { "type": "string" } }
      }
    },
    "legend": {
      "type": "object",
      "required": ["allowed", "forbidden", "runtime_state", "generated_artifacts", "docs", "tests"],
      "properties": {
        "allowed": { "type": "string" },
        "forbidden": { "type": "string" },
        "runtime_state": { "type": "string" },
        "generated_artifacts": { "type": "string" },
        "docs": { "type": "string" },
        "tests": { "type": "string" }
      }
    },
    "validation_commands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stop_condition": {
      "type": "string",
      "minLength": 1
    },
    "planning_readiness": {
      "type": ["object", "null"],
      "additionalProperties": true,
      "properties": {
        "mode": { "type": "string" },
        "version_status": { "type": "string" },
        "current_stage": { "type": "string" },
        "stage_status": {
          "type": "object",
          "additionalProperties": true
        },
        "gate_status": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "gate_blockers": { "type": "array", "items": { "type": "string" } },
        "gate_warnings": { "type": "array", "items": { "type": "string" } },
        "review_status": { "type": "string" },
        "next_action": { "type": "string" }
      }
    },
    "docs_status_report": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "docs_status": {
      "type": "string"
    },
    "markdown_report": {
      "type": "string",
      "minLength": 1
    }
  }
}
