{
  "title": "KVDF Planner State",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "planner_version",
    "current_plan_id",
    "plans"
  ],
  "properties": {
    "planner_version": {
      "type": "string",
      "minLength": 1
    },
    "current_plan_id": {
      "type": ["string", "null"]
    },
    "plans": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "plan_id",
          "status",
          "planner_mode",
          "track",
          "delivery_mode",
          "goal",
          "recommended_evolution",
          "task_punch",
          "codex_prompt",
          "allowed_files",
          "forbidden_files",
          "out_of_scope",
          "validation_commands",
          "stop_condition",
          "created_at",
          "approved_at",
          "approved_by",
          "rejected_at",
          "rejection_reason"
        ],
        "properties": {
          "plan_id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["proposed", "approved", "rejected", "completed"]
          },
          "planner_mode": {
            "type": "string",
            "enum": ["owner", "vibe", "plugin"]
          },
          "track": {
            "type": "string",
            "enum": ["framework_owner", "vibe_app_developer", "plugin"]
          },
          "delivery_mode": {
            "type": "string",
            "enum": ["direct_main", "local_first"]
          },
          "goal": {
            "type": "string",
            "minLength": 1
          },
          "recommended_evolution": {
            "type": "object"
          },
          "task_punch": {
            "type": "object"
          },
          "codex_prompt": {
            "type": "string",
            "minLength": 1
          },
          "allowed_files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "forbidden_files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "out_of_scope": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "validation_commands": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "stop_condition": {
            "type": "string",
            "minLength": 1
          },
          "created_at": {
            "type": "string",
            "minLength": 1
          },
          "approved_at": {
            "type": ["string", "null"]
          },
          "approved_by": {
            "type": ["string", "null"]
          },
          "rejected_at": {
            "type": ["string", "null"]
          },
          "rejection_reason": {
            "type": ["string", "null"]
          }
        }
      }
    }
  }
}
