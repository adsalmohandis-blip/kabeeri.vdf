{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KVDF Planner Docs Materialization",
  "type": "object",
  "required": ["report_type", "planner_mode", "track", "planning_method", "status"],
  "properties": {
    "report_type": { "const": "kvdf_planner_docs_materialization" },
    "planner_mode": { "type": "string" },
    "track": { "type": "string" },
    "planning_method": { "type": "string" },
    "status": { "type": "string" },
    "docs_plan": { "type": "object" },
    "docs_status": { "type": "object" },
    "docs_created": {
      "type": "array",
      "items": { "type": "string" }
    },
    "docs_updated": {
      "type": "array",
      "items": { "type": "string" }
    },
    "docs_skipped": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}

