{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KVDF Viber Pipeline Stage Order",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "report_type",
    "track",
    "delivery_mode",
    "source_of_truth",
    "planning_method",
    "method_policy",
    "planning_authority",
    "questionnaire",
    "brief",
    "docs_design_gates",
    "documentation_folders",
    "documentation_files",
    "portable_docs_mapping",
    "stage_order",
    "stage_groups",
    "stages",
    "readiness",
    "execution_allowed",
    "execution_blockers",
    "next_stage"
  ],
  "properties": {
    "report_type": {
      "type": "string",
      "const": "kvdf_viber_pipeline_stage_order"
    },
    "track": {
      "type": "string",
      "const": "vibe_app_developer"
    },
    "delivery_mode": {
      "type": "string",
      "enum": ["local_first", "local_only", "direct_main", "branch", "branch_pr"]
    },
    "source_of_truth": {
      "type": "string",
      "enum": ["file_first"]
    },
    "planning_method": {
      "type": "string",
      "enum": ["structured", "agile", "hybrid"]
    },
    "method_policy": {
      "type": "object",
      "additionalProperties": true,
      "required": ["method", "foundation_depth", "execution_style", "required_stage_overrides", "deferred_stage_rules", "reason"],
      "properties": {
        "method": { "type": "string", "enum": ["structured", "agile", "hybrid"] },
        "foundation_depth": { "type": "string" },
        "execution_style": { "type": "string" },
        "required_stage_overrides": { "type": "array", "items": { "type": "string" } },
        "deferred_stage_rules": { "type": "array", "items": { "type": "string" } },
        "reason": { "type": "string" }
      }
    },
    "planning_authority": {
      "type": "object",
      "additionalProperties": true,
      "required": ["level", "reason", "state_freshness", "source_of_truth"],
      "properties": {
        "level": { "type": "string", "enum": ["placeholder", "draft", "approved"] },
        "reason": { "type": "string" },
        "current_version": { "type": ["string", "null"] },
        "next_version": { "type": ["string", "null"] },
        "current_evolution": { "type": ["string", "null"] },
        "next_evolution": { "type": ["string", "null"] },
        "state_freshness": { "type": "string", "enum": ["current", "stale", "unknown"] },
        "source_of_truth": { "type": "string", "enum": ["file_first", "runtime_only", "git_supported", "remote_supported", "unknown"] }
      }
    },
    "questionnaire": {
      "type": "object",
      "additionalProperties": true,
      "required": ["status", "questions_total", "answers_total", "missing_answers", "next_action"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["missing", "generated", "answered", "incomplete", "complete", "reviewed", "approved"]
        },
        "path": { "type": ["string", "null"] },
        "questions_total": { "type": "integer", "minimum": 0 },
        "answers_total": { "type": "integer", "minimum": 0 },
        "missing_answers": { "type": "array", "items": { "type": "string" } },
        "reviewed": { "type": "boolean" },
        "approved": { "type": "boolean" },
        "complete": { "type": "boolean" },
        "generated": { "type": "boolean" },
        "next_action": { "type": "string" }
      }
    },
    "brief": {
      "type": "object",
      "additionalProperties": true,
      "required": ["status", "next_action"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["missing", "draft", "reviewed", "approved", "blocked"]
        },
        "path": { "type": ["string", "null"] },
        "reviewed": { "type": "boolean" },
        "approved": { "type": "boolean" },
        "next_action": { "type": "string" }
      }
    },
    "docs_design_gates": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "status",
        "documentation_architecture",
        "documentation_folders",
        "documentation_files",
        "system_design",
        "database_design",
        "ui_ux_design",
        "version_plan",
        "blockers",
        "warnings",
        "next_action"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["ready", "warning", "blocked"]
        },
        "documentation_architecture": { "$ref": "#/$defs/docsDesignGate" },
        "documentation_folders": { "$ref": "#/$defs/docsDesignGate" },
        "documentation_files": { "$ref": "#/$defs/docsDesignGate" },
        "system_design": { "$ref": "#/$defs/docsDesignGate" },
        "database_design": { "$ref": "#/$defs/docsDesignGate" },
        "ui_ux_design": { "$ref": "#/$defs/docsDesignGate" },
        "version_plan": { "$ref": "#/$defs/docsDesignGate" },
        "blockers": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        },
        "warnings": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        },
        "next_action": { "type": "string" }
      }
    },
    "documentation_folders": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["folder_id", "title", "path", "required", "status", "files"],
        "properties": {
          "folder_id": { "type": "string" },
          "title": { "type": "string" },
          "path": { "type": "string" },
          "required": { "type": "boolean" },
          "status": { "type": "string" },
          "required_total": { "type": "integer" },
          "files": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["doc_id", "title", "path", "status", "pipeline_stage"],
              "properties": {
                "doc_id": { "type": "string" },
                "title": { "type": "string" },
                "path": { "type": "string" },
                "status": { "type": "string" },
                "pipeline_stage": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "documentation_files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "portable_docs_mapping": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["planner_doc", "canonical_docs", "mapping_status"],
        "properties": {
          "planner_doc": { "type": "string" },
          "canonical_docs": { "type": "array", "items": { "type": "string" } },
          "mapping_status": { "type": "string" }
        }
      }
    },
    "stage_order": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "idea",
          "questionnaire_generation",
          "questionnaire_answers",
          "answer_completeness_check",
          "brief_generation",
          "brief_review",
          "brief_approval",
          "state_resync",
          "current_state_report",
          "app_boundary",
          "documentation_architecture",
          "documentation_folders",
          "documentation_files",
          "system_design",
          "database_design",
          "ui_ux_design",
          "source_control_plan",
          "security_plan",
          "version_plan",
          "evolutions",
          "evolution_order_validation",
          "task_punches",
          "task_punch_review",
          "approval",
          "materialization",
          "codex_prompt",
          "security_gate",
          "handoff_gate",
          "source_control_gate",
          "execution",
          "validation",
          "security_scan",
          "handoff",
          "dashboard_update",
          "learning_capture",
          "closeout"
        ]
      }
    },
    "stage_groups": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intake", "brief", "state_and_boundary", "documentation_and_design", "planning", "tasking", "execution", "feedback"],
      "properties": {
        "intake": { "type": "array", "items": { "type": "string" } },
        "brief": { "type": "array", "items": { "type": "string" } },
        "state_and_boundary": { "type": "array", "items": { "type": "string" } },
        "documentation_and_design": { "type": "array", "items": { "type": "string" } },
        "planning": { "type": "array", "items": { "type": "string" } },
        "tasking": { "type": "array", "items": { "type": "string" } },
        "execution": { "type": "array", "items": { "type": "string" } },
        "feedback": { "type": "array", "items": { "type": "string" } }
      }
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["stage", "order", "group", "label", "status", "required", "outputs", "blockers", "warnings", "next_action"],
        "properties": {
          "stage": {
            "type": "string",
            "enum": [
              "idea",
              "questionnaire_generation",
              "questionnaire_answers",
              "answer_completeness_check",
              "brief_generation",
              "brief_review",
              "brief_approval",
              "state_resync",
              "current_state_report",
              "app_boundary",
              "documentation_architecture",
              "documentation_folders",
              "documentation_files",
              "system_design",
              "database_design",
              "ui_ux_design",
              "source_control_plan",
              "security_plan",
              "version_plan",
              "evolutions",
              "evolution_order_validation",
              "task_punches",
              "task_punch_review",
              "approval",
              "materialization",
              "codex_prompt",
              "security_gate",
              "handoff_gate",
              "source_control_gate",
              "execution",
              "validation",
              "security_scan",
              "handoff",
              "dashboard_update",
              "learning_capture",
              "closeout"
            ]
          },
          "order": { "type": "integer", "minimum": 1 },
          "group": { "type": "string" },
          "label": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["missing", "planned", "ready", "approved", "materialized", "blocked", "complete", "unknown", "deferred", "not_applicable"]
          },
          "required": { "type": "boolean" },
          "outputs": { "type": "array", "items": { "type": "string" } },
          "blockers": { "type": "array", "items": { "type": "string" } },
          "warnings": { "type": "array", "items": { "type": "string" } },
          "next_action": { "type": "string" }
        }
      }
    },
    "readiness": {
      "type": "object",
      "required": ["status", "blocked_total", "warnings_total", "next_action"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["ready", "warning", "blocked"]
        },
        "blocked_total": { "type": "integer", "minimum": 0 },
        "warnings_total": { "type": "integer", "minimum": 0 },
        "next_action": { "type": "string" }
      }
    },
    "execution_allowed": { "type": "boolean" },
    "execution_blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity", "area", "message", "next_action"],
        "properties": {
          "id": { "type": "string" },
          "severity": { "type": "string", "enum": ["blocker", "warning"] },
          "area": {
            "type": "string",
            "enum": ["state_resync", "docs", "task", "validation", "security", "handoff", "publish", "source_control"]
          },
          "message": { "type": "string" },
          "next_action": { "type": "string" }
        }
      }
    },
    "next_stage": { "type": "string" },
    "state_resync": { "type": ["object", "null"], "additionalProperties": true },
    "docs_plan": { "type": ["object", "null"], "additionalProperties": true },
    "docs_status": { "type": "string" },
    "documentation_architecture": { "type": ["object", "null"], "additionalProperties": true },
    "design_artifacts": { "type": ["object", "null"], "additionalProperties": true },
    "visual_planning": { "type": ["object", "null"], "additionalProperties": true },
    "version_plan": { "type": ["object", "null"], "additionalProperties": true },
    "version_control": { "type": ["object", "null"], "additionalProperties": true },
    "evolutions": { "type": "array" },
    "task_punches": { "type": "array" },
    "evolution_order_validation": { "type": ["object", "null"], "additionalProperties": true },
    "cloud_ready": { "type": "boolean" },
    "consent_required": { "type": "boolean" },
    "owner_approved_for_cloud": { "type": "boolean" },
    "anonymized": { "type": "boolean" },
    "sensitive_items_removed": { "type": "integer", "minimum": 0 },
    "dataset_tags": { "type": "array", "items": { "type": "string" } },
    "training_eligible": { "type": "boolean" },
    "plugin_context": { "type": ["object", "null"], "additionalProperties": true }
  },
  "$defs": {
    "docsDesignGate": {
      "type": "object",
      "additionalProperties": true,
      "required": ["gate", "status", "required", "source", "required_docs", "existing_docs", "missing_docs", "applied_docs", "next_action"],
      "properties": {
        "gate": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["missing", "planned", "generated", "applied_to_stage", "reviewed", "approved", "blocked", "deferred", "not_applicable", "unknown"]
        },
        "required": { "type": "boolean" },
        "source": { "type": "string", "enum": ["planner_docs_status", "pipeline", "derived", "missing"] },
        "required_docs": { "type": "array", "items": { "type": "string" } },
        "existing_docs": { "type": "array", "items": { "type": "string" } },
        "missing_docs": { "type": "array", "items": { "type": "string" } },
        "applied_docs": { "type": "array", "items": { "type": "string" } },
        "next_action": { "type": "string" }
      }
    }
  }
}
