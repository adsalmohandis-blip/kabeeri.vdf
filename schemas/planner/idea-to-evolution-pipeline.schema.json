{
  "title": "KVDF Idea to Evolution Pipeline",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "report_type",
    "planner_mode",
    "track",
    "delivery_mode",
    "source_control",
    "idea",
    "documentation_folders",
    "portable_docs_mapping",
    "documentation_files",
    "design_artifacts",
    "visual_planning",
    "version_plan",
    "evolutions",
    "task_punches",
    "visual_roadmap",
    "next_evolution",
    "next_action"
  ],
  "properties": {
    "report_type": {
      "type": "string",
      "const": "kvdf_idea_to_evolution_pipeline"
    },
    "planner_mode": {
      "type": "string",
      "enum": ["owner", "vibe", "plugin"]
    },
    "track": {
      "type": "string",
      "enum": ["framework_owner", "vibe_app_developer", "plugin"]
    },
    "delivery_mode": {
      "type": "string",
      "enum": ["direct_main", "local_first"]
    },
    "source_control": {
      "type": "object"
    },
    "idea": {
      "type": "string",
      "minLength": 1
    },
    "documentation_folders": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["folder_id", "title", "path", "required", "status", "files"],
        "properties": {
          "folder_id": { "type": "string" },
          "title": { "type": "string" },
          "path": { "type": "string" },
          "required": { "type": "boolean" },
          "status": { "type": "string" },
          "required_total": { "type": "integer" },
          "files": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["doc_id", "title", "path", "status", "pipeline_stage"],
              "properties": {
                "doc_id": { "type": "string" },
                "title": { "type": "string" },
                "path": { "type": "string" },
                "status": { "type": "string" },
                "pipeline_stage": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "portable_docs_mapping": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["planner_doc", "canonical_docs", "mapping_status"],
        "properties": {
          "planner_doc": { "type": "string" },
          "canonical_docs": { "type": "array", "items": { "type": "string" } },
          "mapping_status": { "type": "string" }
        }
      }
    },
    "documentation_files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "design_artifacts": {
      "type": "object"
    },
    "visual_planning": {
      "type": "object",
      "required": ["graph", "board", "scope_map", "legend", "markdown_report", "validation_commands", "stop_condition"],
      "properties": {
        "graph": { "type": "object" },
        "board": { "type": "object" },
        "scope_map": { "type": "object" },
        "legend": { "type": "object" },
        "markdown_report": { "type": "string" },
        "validation_commands": { "type": "array", "items": { "type": "string" } },
        "stop_condition": { "type": "string" }
      }
    },
    "version_plan": {
      "type": "object"
    },
    "evolutions": {
      "type": "array"
    },
    "task_punches": {
      "type": "array"
    },
    "visual_roadmap": {
      "type": "object"
    },
    "next_evolution": {
      "type": "object"
    },
    "validation_commands": {
      "type": "array",
      "items": { "type": "string" }
    },
    "stop_condition": {
      "type": "string"
    },
    "next_action": {
      "type": "string",
      "minLength": 1
    }
  }
}
