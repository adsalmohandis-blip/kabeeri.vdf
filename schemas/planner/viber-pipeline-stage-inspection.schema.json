{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KVDF Viber Pipeline Stage Inspection",
  "type": "object",
  "additionalProperties": true,
  "oneOf": [
    {
      "required": [
        "report_type",
        "track",
        "current_stage",
        "stage",
        "stage_order",
        "stage_group",
        "label",
        "status",
        "required",
        "planning_method",
        "planning_authority",
        "evidence",
        "dependencies",
        "blockers",
        "warnings",
        "transition",
        "next_action"
      ],
      "properties": {
        "report_type": { "const": "kvdf_viber_pipeline_stage_inspection" },
        "track": { "const": "vibe_app_developer" },
        "current_stage": { "type": "string" },
        "stage": { "type": "string" },
        "stage_order": { "type": "integer", "minimum": 1 },
        "stage_group": { "type": "string" },
        "label": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["missing", "planned", "ready", "approved", "materialized", "blocked", "complete", "unknown", "deferred", "not_applicable"]
        },
        "required": { "type": "boolean" },
        "planning_method": { "type": "string", "enum": ["structured", "agile", "hybrid"] },
        "planning_authority": {
          "type": "object",
          "additionalProperties": true,
          "required": ["level", "reason"],
          "properties": {
            "level": { "type": "string", "enum": ["placeholder", "draft", "approved"] },
            "reason": { "type": "string" }
          }
        },
        "evidence": {
          "type": "object",
          "additionalProperties": true,
          "required": ["source_files_inspected", "runtime_files_inspected", "docs_inspected", "summary"],
          "properties": {
            "source_files_inspected": { "type": "array", "items": { "type": "string" } },
            "runtime_files_inspected": { "type": "array", "items": { "type": "string" } },
            "docs_inspected": { "type": "array", "items": { "type": "string" } },
            "summary": { "type": "string" }
          }
        },
        "dependencies": {
          "type": "object",
          "additionalProperties": true,
          "required": ["previous_stage", "required_previous_stages", "required_gates"],
          "properties": {
            "previous_stage": { "type": "string" },
            "required_previous_stages": { "type": "array", "items": { "type": "string" } },
            "required_gates": { "type": "array", "items": { "type": "string" } }
          }
        },
        "blockers": { "type": "array", "items": { "type": "string" } },
        "warnings": { "type": "array", "items": { "type": "string" } },
        "transition": {
          "type": "object",
          "additionalProperties": true,
          "required": ["next_stage", "transition_allowed", "blocked_by", "required_before_next", "next_action"],
          "properties": {
            "next_stage": { "type": "string" },
            "transition_allowed": { "type": "boolean" },
            "blocked_by": { "type": "array", "items": { "type": "string" } },
            "required_before_next": { "type": "array", "items": { "type": "string" } },
            "next_action": { "type": "string" }
          }
        },
        "next_action": { "type": "string" }
      }
    },
    {
      "required": [
        "report_type",
        "track",
        "current_stage",
        "planning_method",
        "planning_authority",
        "stages",
        "evidence",
        "dependencies",
        "blockers",
        "warnings",
        "transition",
        "next_action"
      ],
      "properties": {
        "report_type": { "const": "kvdf_viber_pipeline_stage_inspection" },
        "track": { "const": "vibe_app_developer" },
        "current_stage": { "const": "all" },
        "planning_method": { "type": "string", "enum": ["structured", "agile", "hybrid"] },
        "planning_authority": {
          "type": "object",
          "additionalProperties": true,
          "required": ["level", "reason"],
          "properties": {
            "level": { "type": "string", "enum": ["placeholder", "draft", "approved"] },
            "reason": { "type": "string" }
          }
        },
        "stages": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/stageInspection" }
        },
        "evidence": {
          "type": "object",
          "additionalProperties": true,
          "required": ["source_files_inspected", "runtime_files_inspected", "docs_inspected", "summary"],
          "properties": {
            "source_files_inspected": { "type": "array", "items": { "type": "string" } },
            "runtime_files_inspected": { "type": "array", "items": { "type": "string" } },
            "docs_inspected": { "type": "array", "items": { "type": "string" } },
            "summary": { "type": "string" }
          }
        },
        "dependencies": {
          "type": "object",
          "additionalProperties": true,
          "required": ["previous_stage", "required_previous_stages", "required_gates"],
          "properties": {
            "previous_stage": { "type": "string" },
            "required_previous_stages": { "type": "array", "items": { "type": "string" } },
            "required_gates": { "type": "array", "items": { "type": "string" } }
          }
        },
        "blockers": { "type": "array", "items": { "type": "string" } },
        "warnings": { "type": "array", "items": { "type": "string" } },
        "transition": {
          "type": "object",
          "additionalProperties": true,
          "required": ["next_stage", "transition_allowed", "blocked_by", "required_before_next", "next_action"],
          "properties": {
            "next_stage": { "type": "string" },
            "transition_allowed": { "type": "boolean" },
            "blocked_by": { "type": "array", "items": { "type": "string" } },
            "required_before_next": { "type": "array", "items": { "type": "string" } },
            "next_action": { "type": "string" }
          }
        },
        "next_action": { "type": "string" }
      }
    }
  ],
  "$defs": {
    "stageInspection": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "current_stage",
        "stage",
        "stage_order",
        "stage_group",
        "label",
        "status",
        "required",
        "planning_method",
        "planning_authority",
        "evidence",
        "dependencies",
        "blockers",
        "warnings",
        "transition",
        "next_action"
      ],
      "properties": {
        "current_stage": { "type": "string" },
        "stage": { "type": "string" },
        "stage_order": { "type": "integer", "minimum": 1 },
        "stage_group": { "type": "string" },
        "label": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["missing", "planned", "ready", "approved", "materialized", "blocked", "complete", "unknown", "deferred", "not_applicable"]
        },
        "required": { "type": "boolean" },
        "planning_method": { "type": "string", "enum": ["structured", "agile", "hybrid"] },
        "planning_authority": {
          "type": "object",
          "additionalProperties": true,
          "required": ["level", "reason"],
          "properties": {
            "level": { "type": "string", "enum": ["placeholder", "draft", "approved"] },
            "reason": { "type": "string" }
          }
        },
        "evidence": {
          "type": "object",
          "additionalProperties": true,
          "required": ["source_files_inspected", "runtime_files_inspected", "docs_inspected", "summary"],
          "properties": {
            "source_files_inspected": { "type": "array", "items": { "type": "string" } },
            "runtime_files_inspected": { "type": "array", "items": { "type": "string" } },
            "docs_inspected": { "type": "array", "items": { "type": "string" } },
            "summary": { "type": "string" }
          }
        },
        "dependencies": {
          "type": "object",
          "additionalProperties": true,
          "required": ["previous_stage", "required_previous_stages", "required_gates"],
          "properties": {
            "previous_stage": { "type": "string" },
            "required_previous_stages": { "type": "array", "items": { "type": "string" } },
            "required_gates": { "type": "array", "items": { "type": "string" } }
          }
        },
        "blockers": { "type": "array", "items": { "type": "string" } },
        "warnings": { "type": "array", "items": { "type": "string" } },
        "transition": {
          "type": "object",
          "additionalProperties": true,
          "required": ["next_stage", "transition_allowed", "blocked_by", "required_before_next", "next_action"],
          "properties": {
            "next_stage": { "type": "string" },
            "transition_allowed": { "type": "boolean" },
            "blocked_by": { "type": "array", "items": { "type": "string" } },
            "required_before_next": { "type": "array", "items": { "type": "string" } },
            "next_action": { "type": "string" }
          }
        },
        "next_action": { "type": "string" }
      }
    }
  }
}
