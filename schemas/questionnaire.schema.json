{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Kabeeri VDF Questionnaire Schema",
  "type": "object",
  "required": [
    "folder",
    "purpose",
    "questions",
    "ai_handoff_instructions"
  ],
  "properties": {
    "folder": {
      "type": "string"
    },
    "purpose": {
      "type": "string"
    },
    "recommended_outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "question",
          "answer_type"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "question": {
            "type": "string"
          },
          "answer_type": {
            "enum": [
              "short_text",
              "long_text",
              "choice",
              "multi_choice",
              "table"
            ]
          },
          "choices": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "needs_ai_help_note": {
            "type": "boolean"
          }
        }
      }
    },
    "ai_handoff_instructions": {
      "type": "string"
    }
  }
}
