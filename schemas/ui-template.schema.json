{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kabeeri.local/schemas/ui-template.schema.json",
  "title": "Kabeeri UI Template Metadata",
  "type": "object",
  "required": [
    "templateId",
    "name",
    "businessType",
    "viewType",
    "description",
    "useWhen",
    "requiredComponents",
    "requiredIcons",
    "requiredStates",
    "layoutRules",
    "uxRules",
    "accessibilityRules",
    "antiPatterns",
    "acceptanceCriteria",
    "files"
  ],
  "properties": {
    "templateId": { "type": "string", "minLength": 3 },
    "name": { "type": "string", "minLength": 3 },
    "businessType": { "type": "string", "minLength": 2 },
    "viewType": { "type": "string", "minLength": 2 },
    "description": { "type": "string", "minLength": 10 },
    "useWhen": { "type": "array", "items": { "type": "string" } },
    "requiredComponents": { "type": "array", "items": { "type": "string" } },
    "requiredIcons": { "type": "array", "items": { "type": "string" } },
    "requiredStates": { "type": "array", "items": { "type": "string" } },
    "layoutRules": { "type": "array", "items": { "type": "string" } },
    "uxRules": { "type": "array", "items": { "type": "string" } },
    "accessibilityRules": { "type": "array", "items": { "type": "string" } },
    "antiPatterns": { "type": "array", "items": { "type": "string" } },
    "acceptanceCriteria": { "type": "array", "items": { "type": "string" } },
    "sampleData": { "type": ["object", "array", "null"] },
    "files": {
      "type": "object",
      "properties": {
        "template": { "type": "string" },
        "styles": { "type": "string" },
        "script": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}

