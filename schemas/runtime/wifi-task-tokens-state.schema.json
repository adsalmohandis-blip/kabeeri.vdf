{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Wi-Fi Task Tokens Runtime State",
  "type": "object",
  "required": ["version", "tokens"],
  "properties": {
    "version": { "type": "string" },
    "plugin_id": { "type": "string" },
    "created_at": { "type": ["string", "null"] },
    "updated_at": { "type": ["string", "null"] },
    "tokens": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["wifi_task_token_id", "project_id", "task_id", "wifi_node_id", "status"],
        "properties": {
          "wifi_task_token_id": { "type": "string" },
          "project_id": { "type": "string" },
          "task_id": { "type": "string" },
          "wifi_node_id": { "type": "string" },
          "governance_node_id": { "type": "string" },
          "agent_id": { "type": ["string", "null"] },
          "tool_id": { "type": ["string", "null"] },
          "allowed_actions": { "type": "array", "items": { "type": "string" } },
          "denied_actions": { "type": "array", "items": { "type": "string" } },
          "allowed_paths": { "type": "array", "items": { "type": "string" } },
          "denied_paths": { "type": "array", "items": { "type": "string" } },
          "allowed_services": { "type": "array", "items": { "type": "string" } },
          "denied_services": { "type": "array", "items": { "type": "string" } },
          "allowed_devices": { "type": "array", "items": { "type": "string" } },
          "denied_devices": { "type": "array", "items": { "type": "string" } },
          "max_runtime_seconds": { "type": ["number", "null"] },
          "risk_level": { "type": "string" },
          "created_at": { "type": "string" },
          "expires_at": { "type": ["string", "null"] },
          "status": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
