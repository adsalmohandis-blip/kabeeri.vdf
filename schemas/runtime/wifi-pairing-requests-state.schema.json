{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Wi-Fi Pairing Requests Runtime State",
  "type": "object",
  "required": ["version", "requests"],
  "properties": {
    "version": { "type": "string" },
    "plugin_id": { "type": "string" },
    "created_at": { "type": ["string", "null"] },
    "updated_at": { "type": ["string", "null"] },
    "requests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pairing_request_id", "wifi_node_id", "approval_status", "trust_status"],
        "properties": {
          "pairing_request_id": { "type": "string" },
          "wifi_node_id": { "type": "string" },
          "governance_node_id": { "type": "string" },
          "requested_by": { "type": ["string", "null"] },
          "owner_id": { "type": ["string", "null"] },
          "trust_status": { "type": "string" },
          "approval_status": { "type": "string" },
          "approved_at": { "type": ["string", "null"] },
          "revoked_at": { "type": ["string", "null"] },
          "expires_at": { "type": ["string", "null"] },
          "allowed_projects": { "type": "array", "items": { "type": "string" } },
          "allowed_capabilities": { "type": "array", "items": { "type": "string" } },
          "denied_capabilities": { "type": "array", "items": { "type": "string" } },
          "risk_level": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
