{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KCloud Packet Evidence Runtime State",
  "type": "object",
  "required": ["version", "evidence"],
  "properties": {
    "version": { "type": "string" },
    "created_at": { "type": ["string", "null"] },
    "updated_at": { "type": ["string", "null"] },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kcloud_evidence_id", "created_at", "status"],
        "properties": {
          "kcloud_evidence_id": { "type": "string" },
          "packet_id": { "type": ["string", "null"] },
          "kcloud_node_id": { "type": ["string", "null"] },
          "task_id": { "type": ["string", "null"] },
          "evidence_type": { "type": ["string", "null"] },
          "decision": { "type": ["string", "null"] },
          "reason": { "type": ["string", "null"] },
          "risk_level": { "type": ["string", "null"] },
          "created_at": { "type": "string" },
          "status": { "type": "string" },
          "evidence_source": { "type": ["string", "null"] }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}

