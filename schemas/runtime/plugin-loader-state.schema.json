{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kabeeri.vdf/schemas/runtime/plugin-loader-state.schema.json",
  "title": "Kabeeri Plugin Loader State",
  "type": "object",
  "additionalProperties": true,
  "required": ["plugin_loader_version", "enabled_plugins", "disabled_plugins", "updated_at"],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "plugin_loader_version": {
      "type": "integer",
      "minimum": 1
    },
    "enabled_plugins": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "disabled_plugins": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "updated_at": {
      "type": ["string", "null"]
    }
  }
}
