{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Kabeeri UI Design Advisor State",
  "type": "object",
  "required": ["recommendations", "reviews"],
  "properties": {
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["recommendation_id", "created_at", "blueprint_key", "experience_pattern", "components", "checklist"],
        "properties": {
          "recommendation_id": { "type": "string" },
          "created_at": { "type": "string" },
          "blueprint_key": { "type": "string" },
          "blueprint_name": { "type": "string" },
          "experience_pattern": { "type": "string" },
          "recommended_stacks": { "type": "array", "items": { "type": "string" } },
          "foundations": { "type": "array", "items": { "type": "string" } },
          "components": { "type": "array", "items": { "type": "string" } },
          "page_templates": { "type": "array", "items": { "type": "string" } },
          "seo_geo": { "type": "array", "items": { "type": "string" } },
          "avoid": { "type": "array", "items": { "type": "string" } },
          "checklist": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "reviews": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["review_id", "created_at", "target", "status", "findings"],
        "properties": {
          "review_id": { "type": "string" },
          "created_at": { "type": "string" },
          "target": { "type": "string" },
          "status": { "type": "string" },
          "findings": { "type": "array", "items": { "type": "string" } },
          "checked_rules": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "current_recommendation": { "type": ["string", "null"] }
  }
}
