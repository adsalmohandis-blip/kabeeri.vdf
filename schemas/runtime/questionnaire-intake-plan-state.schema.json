{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KVDF Adaptive Questionnaire Intake Plan State",
  "type": "object",
  "required": ["plans"],
  "properties": {
    "current_plan_id": {
      "type": ["string", "null"]
    },
    "plans": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["plan_id", "created_at", "blueprint", "generated_questions"],
        "properties": {
          "plan_id": { "type": "string" },
          "created_at": { "type": "string" },
          "description": { "type": "string" },
          "goal": { "type": "string" },
          "blueprint": {
            "type": "object",
            "required": ["key", "name"],
            "properties": {
              "key": { "type": "string" },
              "name": { "type": "string" }
            },
            "additionalProperties": true
          },
          "delivery_mode_recommendation": { "type": "object" },
          "framework_context": { "type": "object" },
          "data_design_context": { "type": "object" },
          "ui_ux_context": { "type": "object" },
          "generated_questions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["question_id", "text", "source_systems", "area_ids"],
              "properties": {
                "question_id": { "type": "string" },
                "text": { "type": "string" },
                "why": { "type": "string" },
                "priority": { "type": "string" },
                "answer_type": { "type": "string" },
                "source_systems": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "area_ids": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "choices": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              },
              "additionalProperties": true
            }
          },
          "answer_commands": {
            "type": "array",
            "items": { "type": "string" }
          },
          "next_actions": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
