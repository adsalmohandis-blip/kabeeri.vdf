{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KCloud Policy Decisions Runtime State",
  "type": "object",
  "required": ["version", "decisions"],
  "properties": {
    "version": { "type": "string" },
    "created_at": { "type": ["string", "null"] },
    "updated_at": { "type": ["string", "null"] },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["decision", "reason", "risk_level", "requires_owner_approval", "timestamp"],
        "properties": {
          "decision": { "type": "string" },
          "reason": { "type": "string" },
          "risk_level": { "type": "string" },
          "requires_owner_approval": { "type": "boolean" },
          "tenant_id": { "type": ["string", "null"] },
          "organization_id": { "type": ["string", "null"] },
          "project_id": { "type": ["string", "null"] },
          "cloud_project_id": { "type": ["string", "null"] },
          "kcloud_node_id": { "type": ["string", "null"] },
          "task_id": { "type": ["string", "null"] },
          "kcloud_task_token_id": { "type": ["string", "null"] },
          "kcloud_lease_id": { "type": ["string", "null"] },
          "packet_id": { "type": ["string", "null"] },
          "evidence_id": { "type": ["string", "null"] },
          "timestamp": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}

