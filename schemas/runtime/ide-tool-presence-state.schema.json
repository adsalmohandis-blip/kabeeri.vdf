{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KVDF IDE Tool Presence State",
  "type": "object",
  "additionalProperties": true,
  "required": ["version", "tools"],
  "properties": {
    "version": {
      "type": "string",
      "const": "v1"
    },
    "created_at": {
      "type": ["string", "null"]
    },
    "updated_at": {
      "type": ["string", "null"]
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "tool_id",
          "tool_name",
          "agent_id",
          "session_id",
          "ide_window_id",
          "workspace_id",
          "task_id",
          "status",
          "last_seen_at",
          "capabilities"
        ],
        "properties": {
          "tool_id": { "type": "string" },
          "tool_name": { "type": "string" },
          "agent_id": { "type": "string" },
          "session_id": { "type": "string" },
          "ide_window_id": { "type": ["string", "null"] },
          "workspace_id": { "type": ["string", "null"] },
          "task_id": { "type": ["string", "null"] },
          "status": { "type": "string" },
          "last_seen_at": { "type": "string" },
          "capabilities": { "type": "array", "items": { "type": "string" } },
          "registered_at": { "type": ["string", "null"] },
          "updated_at": { "type": ["string", "null"] }
        }
      }
    }
  }
}
