{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KCloud Project Map Runtime State",
  "type": "object",
  "required": ["version", "project_mappings"],
  "properties": {
    "version": { "type": "string" },
    "created_at": { "type": ["string", "null"] },
    "updated_at": { "type": ["string", "null"] },
    "project_mappings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["cloud_project_id", "project_id", "local_project_id", "tenant_id", "status"],
        "properties": {
          "cloud_project_id": { "type": "string" },
          "project_id": { "type": ["string", "null"] },
          "local_project_id": { "type": ["string", "null"] },
          "tenant_id": { "type": ["string", "null"] },
          "organization_id": { "type": ["string", "null"] },
          "owner_id": { "type": ["string", "null"] },
          "user_id": { "type": ["string", "null"] },
          "role_id": { "type": ["string", "null"] },
          "repo_root": { "type": ["string", "null"] },
          "last_synced_at": { "type": ["string", "null"] },
          "status": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}

