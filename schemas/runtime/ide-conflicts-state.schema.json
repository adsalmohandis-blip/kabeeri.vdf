{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KVDF IDE Conflicts State",
  "type": "object",
  "additionalProperties": true,
  "required": ["version", "conflicts"],
  "properties": {
    "version": {
      "type": "string",
      "const": "v1"
    },
    "created_at": {
      "type": ["string", "null"]
    },
    "updated_at": {
      "type": ["string", "null"]
    },
    "conflicts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "conflict_id",
          "lease_id",
          "ide_window_id",
          "workspace_id",
          "task_id",
          "agent_id",
          "tool_id",
          "conflict_type",
          "severity",
          "path",
          "reason",
          "created_at",
          "status"
        ],
        "properties": {
          "conflict_id": { "type": "string" },
          "lease_id": { "type": "string" },
          "other_lease_id": { "type": ["string", "null"] },
          "ide_window_id": { "type": ["string", "null"] },
          "workspace_id": { "type": ["string", "null"] },
          "task_id": { "type": ["string", "null"] },
          "agent_id": { "type": ["string", "null"] },
          "tool_id": { "type": ["string", "null"] },
          "conflict_type": { "type": "string" },
          "severity": { "type": "string" },
          "path": { "type": ["string", "null"] },
          "reason": { "type": "string" },
          "created_at": { "type": "string" },
          "status": { "type": "string" }
        }
      }
    }
  }
}
