{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KVDF Local Sessions State",
  "type": "object",
  "additionalProperties": true,
  "required": ["version", "sessions"],
  "properties": {
    "version": { "type": "string", "const": "v1" },
    "created_at": { "type": ["string", "null"] },
    "updated_at": { "type": ["string", "null"] },
    "sessions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "session_id",
          "client_id",
          "client_type",
          "machine_id",
          "project_id",
          "repo_root",
          "process_hint",
          "status",
          "opened_at",
          "last_seen_at",
          "capabilities"
        ],
        "properties": {
          "session_id": { "type": "string" },
          "client_id": { "type": ["string", "null"] },
          "client_type": { "type": "string" },
          "machine_id": { "type": ["string", "null"] },
          "project_id": { "type": ["string", "null"] },
          "repo_root": { "type": ["string", "null"] },
          "ide_window_id": { "type": ["string", "null"] },
          "agent_id": { "type": ["string", "null"] },
          "tool_id": { "type": ["string", "null"] },
          "active_task_id": { "type": ["string", "null"] },
          "branch": { "type": ["string", "null"] },
          "process_hint": { "type": ["string", "null"] },
          "status": { "type": "string" },
          "opened_at": { "type": "string" },
          "last_seen_at": { "type": "string" },
          "capabilities": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
