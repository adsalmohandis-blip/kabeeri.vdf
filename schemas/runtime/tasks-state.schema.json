{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KVDF Tasks State",
  "type": "object",
  "required": ["tasks"],
  "properties": {
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "status"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["proposed", "approved", "ready", "assigned", "in_progress", "review", "owner_verified", "rejected"]
          },
          "type": { "type": "string" },
          "workstream": { "type": "string" },
          "workstreams": { "type": "array", "items": { "type": "string" } },
          "app_username": { "type": ["string", "null"] },
          "app_usernames": { "type": "array", "items": { "type": "string" } },
          "app_paths": { "type": "array", "items": { "type": "string" } },
          "allowed_files": { "type": "array", "items": { "type": "string" } },
          "sprint_id": { "type": ["string", "null"] },
          "source": { "type": "string" },
          "acceptance_criteria": { "type": "array", "items": { "type": "string" } },
          "follow_up_tasks": { "type": "array", "items": { "type": "string" } },
          "assignee_id": { "type": "string" },
          "execution_summary": { "type": "string" },
          "memory": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "memory_type": { "type": "string" },
              "version": { "type": "number" },
              "task_id": { "type": "string" },
              "title": { "type": "string" },
              "status": { "type": "string" },
              "purpose": { "type": "string" },
              "summary": { "type": "string" },
              "scope": { "type": "string" },
              "source_of_truth": { "type": "object", "additionalProperties": true },
              "acceptance_criteria": { "type": "array", "items": { "type": "string" } },
              "follow_up_tasks": { "type": "array", "items": { "type": "string" } },
              "required_inputs": { "type": "array", "items": { "type": "string" } },
              "expected_outputs": { "type": "array", "items": { "type": "string" } },
              "do_not_change": { "type": "array", "items": { "type": "string" } },
              "resume_steps": { "type": "array", "items": { "type": "string" } },
              "verification_commands": { "type": "array", "items": { "type": "string" } }
            }
          },
          "resume_steps": { "type": "array", "items": { "type": "string" } },
          "required_inputs": { "type": "array", "items": { "type": "string" } },
          "expected_outputs": { "type": "array", "items": { "type": "string" } },
          "do_not_change": { "type": "array", "items": { "type": "string" } },
          "verification_commands": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
