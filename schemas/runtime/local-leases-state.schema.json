{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KVDF Local Leases State",
  "type": "object",
  "additionalProperties": true,
  "required": ["version", "leases"],
  "properties": {
    "version": { "type": "string", "const": "v1" },
    "created_at": { "type": ["string", "null"] },
    "updated_at": { "type": ["string", "null"] },
    "leases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "lease_id",
          "machine_id",
          "project_id",
          "client_id",
          "session_id",
          "lease_type",
          "scope",
          "allowed_paths",
          "denied_paths",
          "created_at",
          "expires_at",
          "status"
        ],
        "properties": {
          "lease_id": { "type": "string" },
          "machine_id": { "type": ["string", "null"] },
          "project_id": { "type": ["string", "null"] },
          "client_id": { "type": ["string", "null"] },
          "session_id": { "type": ["string", "null"] },
          "agent_id": { "type": ["string", "null"] },
          "tool_id": { "type": ["string", "null"] },
          "task_id": { "type": ["string", "null"] },
          "lease_type": {
            "type": "string",
            "enum": ["task", "file", "folder", "branch"]
          },
          "scope": { "type": ["string", "null"] },
          "allowed_paths": { "type": "array", "items": { "type": "string" } },
          "denied_paths": { "type": "array", "items": { "type": "string" } },
          "branch": { "type": ["string", "null"] },
          "created_at": { "type": "string" },
          "expires_at": { "type": ["string", "null"] },
          "status": {
            "type": "string",
            "enum": ["active", "released", "expired", "blocked"]
          },
          "shared_task": { "type": "boolean" },
          "ide_window_id": { "type": ["string", "null"] },
          "released_at": { "type": ["string", "null"] },
          "last_seen_at": { "type": ["string", "null"] }
        }
      }
    }
  }
}
