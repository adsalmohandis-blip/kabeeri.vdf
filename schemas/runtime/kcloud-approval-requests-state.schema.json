{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KCloud Approval Requests Runtime State",
  "type": "object",
  "required": ["version", "requests"],
  "properties": {
    "version": { "type": "string" },
    "created_at": { "type": ["string", "null"] },
    "updated_at": { "type": ["string", "null"] },
    "requests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kcloud_approval_request_id", "status", "created_at", "updated_at"],
        "properties": {
          "kcloud_approval_request_id": { "type": "string" },
          "tenant_id": { "type": ["string", "null"] },
          "organization_id": { "type": ["string", "null"] },
          "project_id": { "type": ["string", "null"] },
          "cloud_project_id": { "type": ["string", "null"] },
          "kcloud_node_id": { "type": ["string", "null"] },
          "task_id": { "type": ["string", "null"] },
          "packet_id": { "type": ["string", "null"] },
          "reason": { "type": ["string", "null"] },
          "risk_level": { "type": ["string", "null"] },
          "status": { "type": "string" },
          "created_at": { "type": "string" },
          "updated_at": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}

