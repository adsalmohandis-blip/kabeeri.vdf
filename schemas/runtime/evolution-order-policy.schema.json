{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KVDF Evolution Order Policy",
  "type": "object",
  "additionalProperties": true,
  "required": ["report_type", "track", "ordered_categories", "rules"],
  "properties": {
    "report_type": {
      "type": "string",
      "const": "kvdf_evolution_order_policy"
    },
    "track": {
      "type": "string",
      "enum": ["vibe_app_developer", "framework_owner", "plugin"]
    },
    "ordered_categories": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["order", "category", "title"],
        "properties": {
          "order": { "type": "integer", "minimum": 1 },
          "category": { "type": "string" },
          "title": { "type": "string" }
        }
      }
    },
    "rules": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
