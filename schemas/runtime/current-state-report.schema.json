{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KVDF Current State Report",
  "type": "object",
  "required": [
    "report_type",
    "generated_at",
    "status",
    "track",
    "state_freshness",
    "repo",
    "source_control",
    "source_of_truth_priority",
    "file_state",
    "git_evidence",
    "remote_evidence",
    "runtime_state",
    "completed_evolutions",
    "active_evolution",
    "planned_evolutions",
    "future_only_evolutions",
    "stale_docs",
    "conflicts",
    "recommended_next_evolution",
    "do_not_proceed",
    "owner_questions",
    "next_action"
  ],
  "properties": {
    "report_type": { "const": "kvdf_current_state_report" },
    "generated_at": { "type": "string" },
    "status": { "type": "string" },
    "track": { "type": "string" },
    "state_freshness": { "type": "string" },
    "repo": { "type": "object", "additionalProperties": true },
    "source_control": { "type": "object", "additionalProperties": true },
    "source_of_truth_priority": { "type": "array", "items": { "type": "string" } },
    "file_state": { "type": "object", "additionalProperties": true },
    "git_evidence": { "type": "object", "additionalProperties": true },
    "remote_evidence": { "type": "object", "additionalProperties": true },
    "runtime_state": { "type": "object", "additionalProperties": true },
    "completed_evolutions": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "active_evolution": { "type": ["object", "null"], "additionalProperties": true },
    "planned_evolutions": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "future_only_evolutions": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "stale_docs": { "type": "array", "items": { "type": ["string", "object"] } },
    "conflicts": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "recommended_next_evolution": { "type": ["object", "null"], "additionalProperties": true },
    "do_not_proceed": { "type": "boolean" },
    "owner_questions": { "type": "array", "items": { "type": "string" } },
    "next_action": { "type": "string" }
  },
  "additionalProperties": true
}
