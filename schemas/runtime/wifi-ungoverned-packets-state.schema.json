{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Wi-Fi Ungoverned Packets Runtime State",
  "type": "object",
  "required": ["version", "packets"],
  "properties": {
    "version": { "type": "string" },
    "plugin_id": { "type": "string" },
    "created_at": { "type": ["string", "null"] },
    "updated_at": { "type": ["string", "null"] },
    "packets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ungoverned_packet_id", "packet_id", "status"],
        "properties": {
          "ungoverned_packet_id": { "type": "string" },
          "packet_id": { "type": "string" },
          "project_id": { "type": ["string", "null"] },
          "wifi_node_id": { "type": ["string", "null"] },
          "governance_node_id": { "type": ["string", "null"] },
          "task_id": { "type": ["string", "null"] },
          "path": { "type": ["string", "null"] },
          "action": { "type": ["string", "null"] },
          "reason": { "type": ["string", "null"] },
          "timestamp": { "type": ["string", "null"] },
          "status": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
