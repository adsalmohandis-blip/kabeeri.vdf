{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KVDF Owner Dashboard State",
  "type": "object",
  "required": [
    "report_type",
    "dashboard_type",
    "track",
    "title",
    "widgets",
    "tables",
    "sections",
    "blocked_cross_track_data"
  ],
  "properties": {
    "report_type": { "const": "kvdf_owner_dashboard_state" },
    "dashboard_type": { "const": "owner" },
    "track": { "const": "framework_owner" },
    "title": { "const": "KVDF Owner Dashboard" },
    "subtitle": { "type": "string" },
    "generated_at": { "type": ["string", "null"] },
    "widgets": {
      "type": "array",
      "items": { "$ref": "#/$defs/widget" }
    },
    "tables": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/table" }
    },
    "sections": {
      "type": "object",
      "required": [
        "command_center",
        "core_health",
        "planner",
        "evolutions",
        "source_control",
        "workflows",
        "native_capabilities",
        "plugins",
        "ai_cost_control",
        "docs_reports",
        "governance"
      ],
      "properties": {
        "command_center": { "$ref": "#/$defs/section" },
        "core_health": { "$ref": "#/$defs/section" },
        "planner": { "$ref": "#/$defs/section" },
        "evolutions": { "$ref": "#/$defs/section" },
        "source_control": { "$ref": "#/$defs/section" },
        "workflows": { "$ref": "#/$defs/section" },
        "native_capabilities": { "$ref": "#/$defs/section" },
        "plugins": { "$ref": "#/$defs/section" },
        "ai_cost_control": { "$ref": "#/$defs/section" },
        "docs_reports": { "$ref": "#/$defs/section" },
        "governance": { "$ref": "#/$defs/section" }
      },
      "additionalProperties": true
    },
    "blocked_cross_track_data": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source_control": { "type": "object", "additionalProperties": true },
    "planner": { "type": ["object", "null"], "additionalProperties": true },
    "next_action": { "type": "string" },
    "current_plan_id": { "type": ["string", "null"] },
    "current_plan_status": { "type": "string" },
    "current_evolution": { "type": ["string", "null"] }
  },
  "$defs": {
    "widget": {
      "type": "object",
      "required": ["id", "title", "type", "status", "track", "source", "next_action"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string" },
        "value": {},
        "status": { "type": "string" },
        "track": { "type": "string" },
        "source": { "type": "string" },
        "next_action": { "type": "string" }
      },
      "additionalProperties": true
    },
    "table": {
      "type": "object",
      "required": ["id", "title", "columns", "rows", "empty_state"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "columns": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rows": {
          "type": "array",
          "items": { "type": "array" }
        },
        "empty_state": { "type": "string" }
      },
      "additionalProperties": true
    },
    "section": {
      "type": "object",
      "required": ["id", "title", "widgets", "tables"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "widgets": {
          "type": "array",
          "items": { "$ref": "#/$defs/widget" }
        },
        "tables": {
          "type": "array",
          "items": { "$ref": "#/$defs/table" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
