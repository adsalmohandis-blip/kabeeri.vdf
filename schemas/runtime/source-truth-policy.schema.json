{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KVDF Source Truth And Workspace Boundary Policy",
  "type": "object",
  "required": [
    "source_of_truth",
    "workspace",
    "track",
    "allowed_paths",
    "forbidden_paths",
    "write_policy",
    "stale_state"
  ],
  "properties": {
    "source_of_truth": { "type": "object", "additionalProperties": true },
    "workspace": { "type": "object", "additionalProperties": true },
    "track": { "type": "object", "additionalProperties": true },
    "allowed_paths": { "type": "array", "items": { "type": "string" } },
    "forbidden_paths": { "type": "array", "items": { "type": "string" } },
    "write_policy": { "type": "object", "additionalProperties": true },
    "stale_state": { "type": "object", "additionalProperties": true },
    "next_action": { "type": "string" }
  },
  "additionalProperties": true
}
