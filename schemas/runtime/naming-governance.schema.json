{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "KVDF Naming Governance Report",
  "type": "object",
  "required": ["report_type"],
  "properties": {
    "report_type": {
      "type": "string",
      "enum": [
        "kvdf_naming_preview",
        "kvdf_naming_validation"
      ]
    },
    "track": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "title": {
      "type": ["string", "null"]
    },
    "generated_id": {
      "type": ["string", "null"]
    },
    "valid": {
      "type": ["boolean", "null"]
    },
    "rules_applied": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string"
    },
    "checks": {
      "type": "array"
    },
    "next_action": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
