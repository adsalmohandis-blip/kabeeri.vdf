{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "KVDF Naming Governance Report",
  "type": "object",
  "required": ["report_type"],
  "properties": {
    "report_type": {
      "type": "string",
      "enum": [
        "kvdf_naming_preview",
        "kvdf_naming_validation",
        "kvdf_naming_migration_plan"
      ]
    },
    "track": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "title": {
      "type": ["string", "null"]
    },
    "generated_id": {
      "type": ["string", "null"]
    },
    "valid": {
      "type": ["boolean", "null"]
    },
    "rules_applied": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string"
    },
    "checks": {
      "type": "array"
    },
    "next_action": {
      "type": "string"
    },
    "scanned": {
      "type": "object",
      "additionalProperties": true
    },
    "invalid_ids": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "missing_normalized_ids": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "legacy_only": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "duplicates": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "cross_track_collisions": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "recommendations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "dry_run": {
      "type": "boolean"
    },
    "changes": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
