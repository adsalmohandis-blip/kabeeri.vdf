{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kabeeri.vdf/schemas/sprint-cost-metadata.schema.json",
  "title": "Kabeeri Sprint Cost Metadata",
  "type": "object",
  "required": ["sprint_id", "currency", "totals"],
  "properties": {
    "sprint_id": { "type": "string" },
    "currency": { "type": "string", "default": "USD" },
    "totals": {
      "type": "object",
      "required": ["input_tokens", "output_tokens", "total_tokens", "cost"],
      "properties": {
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "cached_tokens": { "type": "integer", "minimum": 0, "default": 0 },
        "total_tokens": { "type": "integer", "minimum": 0 },
        "cost": { "type": "number", "minimum": 0 }
      }
    },
    "by_story": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["story_id", "total_tokens", "cost", "status"],
        "properties": {
          "story_id": { "type": "string" },
          "total_tokens": { "type": "integer", "minimum": 0 },
          "cost": { "type": "number", "minimum": 0 },
          "status": { "type": "string", "enum": ["accepted", "rework", "rejected", "untracked"] }
        }
      },
      "default": []
    },
    "by_workstream": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "total_tokens": { "type": "integer", "minimum": 0 },
          "cost": { "type": "number", "minimum": 0 }
        }
      }
    }
  },
  "additionalProperties": false
}
