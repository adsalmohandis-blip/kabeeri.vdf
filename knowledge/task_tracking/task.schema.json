{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/kabeeri-vdf/task.schema.json",
  "title": "Kabeeri VDF Task Tracking Schema",
  "type": "object",
  "required": [
    "tasks"
  ],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema or framework version.",
      "default": "v0.1.1"
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "status",
          "folder"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique task ID.",
            "examples": [
              "T001",
              "T006"
            ]
          },
          "title": {
            "type": "string",
            "description": "Short clear task title."
          },
          "status": {
            "type": "string",
            "enum": [
              "todo",
              "in_progress",
              "blocked",
              "review",
              "done",
              "closed"
            ],
            "description": "Current task status."
          },
          "type": {
            "type": "string",
            "enum": [
              "docs",
              "generator",
              "questionnaire",
              "prompt-pack",
              "task-tracking",
              "acceptance",
              "example",
              "cli",
              "review",
              "release",
              "other"
            ]
          },
          "priority": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ],
            "default": "medium"
          },
          "prompt_id": {
            "type": "string",
            "description": "Related prompt ID if any.",
            "examples": [
              "P001"
            ]
          },
          "folder": {
            "type": "string",
            "description": "Related framework folder.",
            "examples": [
              "05_EXECUTION_PLAN",
              "task_tracking"
            ]
          },
          "issue": {
            "type": "string",
            "description": "Related GitHub Issue.",
            "examples": [
              "#6"
            ]
          },
          "milestone": {
            "type": "string",
            "description": "Related milestone.",
            "examples": [
              "v0.1.1"
            ]
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "allowed_files": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "forbidden_files": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "tests": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "acceptance_criteria": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "delivery_mode": {
            "type": "string",
            "enum": [
              "structured",
              "agile"
            ],
            "description": "Kabeeri delivery mode for this task."
          },
          "intake_mode": {
            "type": "string",
            "enum": [
              "new_project",
              "existing_kabeeri",
              "existing_non_kabeeri"
            ],
            "description": "How the project or task entered Kabeeri."
          },
          "workstream": {
            "type": "string",
            "description": "Business, technical, or delivery workstream."
          },
          "source_type": {
            "type": "string",
            "description": "Task source type. See governance/TASK_GOVERNANCE.md and TASK_PROVENANCE_SCHEMA.json."
          },
          "source_mode": {
            "type": "string",
            "enum": [
              "direct",
              "indirect",
              "derived",
              "suggested",
              "required"
            ]
          },
          "source_reference": {
            "type": "string",
            "description": "Reference to the source question, document, story, issue, scan, or decision."
          },
          "creator": {
            "type": "string"
          },
          "assignee": {
            "type": "string"
          },
          "reviewer": {
            "type": "string"
          },
          "review_notes": {
            "type": "string",
            "default": ""
          },
          "commit_message": {
            "type": "string",
            "default": ""
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
